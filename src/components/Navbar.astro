---
export interface Props {
  lang?: 'ar' | 'en';
  currentPath?: string;
}

const { lang = 'ar', currentPath = '/' } = Astro.props;

const isAr = lang === 'ar';

const links = isAr
  ? [
      { href: '/',         label: 'الرئيسية' },
      { href: '/blog/',    label: 'المدونة'  },
    ]
  : [
      { href: '/en/',      label: 'Home' },
      { href: '/en/blog/', label: 'Blog' },
    ];

// Smart language switch: stay on same page when switching language
let altHref: string;

// Page mapping for Arabic to English (with trailing slashes)
const pageMap: Record<string, string> = {
  '/': '/en/',
  '/blog/': '/en/blog/',
  '/privacy/': '/en/privacy/',
  '/terms/': '/en/terms/',
  '/disclaimer/': '/en/disclaimer/',
};

// Reverse mapping for English to Arabic
const reversePageMap: Record<string, string> = Object.fromEntries(
  Object.entries(pageMap).map(([ar, en]) => [en, ar])
);

if (isAr) {
  // Arabic -> English
  if (currentPath.startsWith('/blog/') && currentPath !== '/blog/') {
    // Blog post: switch to English version
    const slug = currentPath.replace('/blog/', '').replace(/\/$/, '');
    altHref = `/en/blog/${slug}/`;
  } else {
    // Static page: use mapping or default to /en/
    altHref = pageMap[currentPath] || '/en/';
  }
} else {
  // English -> Arabic
  if (currentPath.startsWith('/en/blog/') && currentPath !== '/en/blog/') {
    // Blog post: switch to Arabic version
    const slug = currentPath.replace('/en/blog/', '').replace(/\/$/, '');
    altHref = `/blog/${slug}/`;
  } else {
    // Static page: use reverse mapping or default to /
    altHref = reversePageMap[currentPath] || '/';
  }
}

// Flag: 🇸🇦 when showing Arabic site (switch to English), 🇺🇸 when showing English (switch to Arabic)
const altFlag = isAr ? 'EN' : 'عر';
const altTitle = isAr ? 'English' : 'العربية';
---

<nav class="navbar" aria-label={isAr ? 'التنقل الرئيسي' : 'Main navigation'}>
  <div class="navbar-inner">
    <a class="navbar-logo" href={isAr ? '/' : '/en/'} aria-label="Home">
      <img src="/YAA-white.svg" alt="Yasir Aljiyadi" height="36" width="auto" />
    </a>

    <ul class="navbar-links" role="list">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            class={
              currentPath === l.href ||
              (currentPath.startsWith(l.href.replace(/\/$/, '') + '/') &&
               l.href !== '/' && l.href !== '/en/')
                ? 'active' : ''
            }
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="navbar-end">
      <a href={altHref} class="lang-btn" title={altTitle} aria-label={altTitle}>
        {altFlag}
      </a>
    </div>
  </div>
</nav>
