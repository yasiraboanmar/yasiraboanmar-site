---
import Base from '../../../layouts/Base.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const quizzes = (await getCollection('quizzes_en'))
  .sort((a, b) => {
    const order = ['general-employees', 'hr-specialists'];
    return order.indexOf(a.id) - order.indexOf(b.id);
  });

const currentPath = Astro.url.pathname;
---

<Base
  title="Quizzes — Yasir Aljiyadi"
  description="Interactive quizzes on Saudi Labor Law. Test your knowledge with questions directly referenced to the law's articles."
  lang="en"
  dir="ltr"
>
  <Navbar lang="en" currentPath={currentPath} />

  <div class="page-header">
    <div class="container">
      <span class="section-label">Interactive Quizzes</span>
      <h1 class="section-title">Quizzes</h1>
      <p class="section-desc">Test your Saudi Labor Law knowledge with questions referenced directly to the law's articles — and discover where you stand.</p>
    </div>
  </div>

  <div class="divider"></div>

  <section class="section">
    <div class="container">
      <div class="quizzes-grid">
        {quizzes.map(q => {
          const quizPath   = `/en/quizzes/${q.id}/`;
          const quizUrl    = `https://yasiraboanmar.com${quizPath}`;
          const inviteTxt  = `Test your knowledge with the "${q.data.title}" quiz on Saudi Labor Law`;
          const inviteMsg  = `${inviteTxt}\n${quizUrl}`;
          const waUrl      = `https://api.whatsapp.com/send?text=${encodeURIComponent(inviteMsg)}`;
          const xUrl       = `https://twitter.com/intent/tweet?text=${encodeURIComponent(inviteMsg)}`;
          const liUrl      = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(quizUrl)}`;
          return (
            <div class="quiz-card-outer">
              <a href={quizPath} class="quiz-card card">
                <div class="quiz-card-header">
                  <span class="quiz-card-badge">Interactive Quiz</span>
                </div>
                <h2 class="quiz-card-title">{q.data.title}</h2>
                <p class="quiz-card-desc">{q.data.description}</p>
                <div class="quiz-card-meta">
                  <div class="quiz-meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    <span>{q.data.audience}</span>
                  </div>
                  <div class="quiz-meta-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span>{q.data.total_questions} questions</span>
                  </div>
                  <div class="quiz-meta-item" style="display:none" data-count-wrap>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    <span data-quiz-count-id={q.id}></span>
                  </div>
                </div>
                <div class="quiz-card-cta">
                  Start Quiz
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                </div>
              </a>
              <div class="quiz-card-invite">
                <span class="qci-label">Invite others:</span>
                <a href={waUrl} target="_blank" rel="noopener" class="qci-btn" title="WhatsApp" aria-label="Share via WhatsApp">
                  <svg width="15" height="15" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 3C8.832 3 3 8.832 3 16c0 2.385.638 4.686 1.84 6.695L3 29l6.48-1.8A13 13 0 0 0 16 29c7.168 0 13-5.832 13-13S23.168 3 16 3zm-3.184 7.355c.2 0 .406.003.584.01.2.008.46-.076.718.548.268.648.908 2.218.988 2.378.08.16.132.346.026.558-.1.207-.15.334-.298.515-.148.183-.313.408-.447.547-.148.15-.302.312-.13.613.173.3.768 1.266 1.649 2.05 1.132 1.01 2.087 1.322 2.387 1.47.3.15.476.126.65-.075.174-.2.744-.867.942-1.165.197-.298.395-.248.665-.15.27.1 1.716.81 2.01.957.296.148.493.222.566.345.074.123.074.713-.173 1.402-.248.688-1.46 1.354-1.996 1.403-.51.046-1.008.23-3.4-.71-2.862-1.12-4.666-4.057-4.808-4.244-.14-.187-1.15-1.527-1.15-2.914 0-1.386.727-2.07 1.025-2.35.224-.214.483-.267.644-.267z"/></svg>
                </a>
                <a href={xUrl} target="_blank" rel="noopener" class="qci-btn" title="X (Twitter)" aria-label="Share via X">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.26 5.632 5.905-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href={liUrl} target="_blank" rel="noopener" class="qci-btn" title="LinkedIn" aria-label="Share via LinkedIn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <button class="qci-btn" data-copy-url={quizUrl} title="Copy link" aria-label="Copy link">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <Footer lang="en" />

  <script is:inline>
  (function() {
    fetch('/api/quiz-stats')
      .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
      .then(function(data) {
        document.querySelectorAll('[data-quiz-count-id]').forEach(function(el) {
          var id = el.getAttribute('data-quiz-count-id');
          var n = data[id];
          if (typeof n === 'number' && n > 0) {
            el.textContent = 'Completed by ' + n.toLocaleString('en') + ' people so far';
            el.closest('[data-count-wrap]').style.display = 'flex';
          }
        });
      })
      .catch(function() {});

    document.querySelectorAll('[data-copy-url]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var url  = btn.getAttribute('data-copy-url');
        var orig = btn.innerHTML;
        navigator.clipboard.writeText(url).then(function() {
          btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(function() { btn.innerHTML = orig; }, 1800);
        }).catch(function() {});
      });
    });
  })();
  </script>
</Base>

<style>
  .quizzes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .quiz-card-outer {
    display: flex; flex-direction: column;
    transition: transform .2s, box-shadow .2s;
  }
  .quiz-card-outer:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(158,230,207,.07);
  }
  .quiz-card-outer:hover > .quiz-card {
    border-color: var(--accent-border);
  }
  .quiz-card-outer > .quiz-card {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }

  .quiz-card {
    display: flex; flex-direction: column; gap: 12px;
    padding: 28px; text-decoration: none; color: var(--text);
    transition: border-color .2s;
  }
  .quiz-card:hover { text-decoration: none; color: var(--text); }

  .quiz-card-header { margin-bottom: 2px; }
  .quiz-card-badge {
    display: inline-block; padding: 3px 12px; border-radius: 999px;
    background: var(--accent-dim); border: 1px solid var(--accent-border);
    color: var(--accent); font-size: .75rem; font-weight: 700;
  }

  .quiz-card-title { font-size: 1.1rem; font-weight: 800; line-height: 1.4; }
  .quiz-card-desc  { font-size: .88rem; color: var(--muted); line-height: 1.7; flex: 1; }

  .quiz-card-meta  { display: flex; flex-direction: column; gap: 6px; }
  .quiz-meta-item  { display: flex; align-items: center; gap: 6px; font-size: .82rem; color: var(--muted); }

  .quiz-card-cta {
    display: flex; align-items: center; gap: 6px;
    font-size: .88rem; color: var(--accent); font-weight: 700;
    margin-top: 4px;
  }

  /* Invite row */
  .quiz-card-invite {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    padding: 10px 16px;
    border: 1px solid var(--border); border-top: 0;
    border-bottom-left-radius: 14px; border-bottom-right-radius: 14px;
    background: rgba(255,255,255,.015);
    font-family: var(--font);
  }
  .qci-label {
    font-size: .72rem; color: var(--muted);
    margin-inline-end: 2px; white-space: nowrap;
  }
  .qci-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 10px;
    border: 1px solid var(--border); background: none;
    color: var(--muted); cursor: pointer;
    transition: color .15s, border-color .15s, background .15s;
    text-decoration: none; padding: 0; flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .qci-btn:hover  { color: var(--accent); border-color: var(--accent-border); text-decoration: none; }
  .qci-btn:active { background: rgba(158,230,207,.08); }

  @media (max-width: 768px) {
    .quizzes-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .qci-label { display: none; }
    .quiz-card-invite { justify-content: flex-end; gap: 6px; padding: 8px 12px; }
    .qci-btn { width: 44px; height: 44px; border-radius: 12px; }
  }
</style>
