---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: 'ar' | 'en';
  dir?: 'rtl' | 'ltr';
}

const {
  title,
  description = 'ياسر الجيادي — مدونة الموارد البشرية | HR Blog',
  image = '/Yasir-Aljiyadi-photo.png',
  lang = 'ar',
  dir = 'rtl',
} = Astro.props;

const canonical = Astro.url.href;
---

<!doctype html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://yasiraboanmar.com${image}`} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://yasiraboanmar.com${image}`} />

  <!-- Hreflang -->
  {lang === 'ar' && <link rel="alternate" hreflang="ar" href="https://yasiraboanmar.com/" />}
  {lang === 'ar' && <link rel="alternate" hreflang="en" href="https://yasiraboanmar.com/en/" />}
  {lang === 'en' && <link rel="alternate" hreflang="en" href="https://yasiraboanmar.com/en/" />}
  {lang === 'en' && <link rel="alternate" hreflang="ar" href="https://yasiraboanmar.com/" />}
  <link rel="alternate" hreflang="x-default" href="https://yasiraboanmar.com/" />

  <!-- RSS -->
  <link
    rel="alternate"
    type="application/rss+xml"
    title={lang === 'ar' ? 'ياسر الجيادي — مدونة HR' : 'Yasir Aljiyadi — HR Blog'}
    href={lang === 'ar' ? '/rss.xml' : '/en/rss.xml'}
  />

  <!-- Favicon -->
  <link rel="icon" href="/Y-icon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/Y-icon.svg" />

  <!-- Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" />
  </noscript>

  <!-- Google Consent Mode v2 -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    // Default consent to denied (will be updated based on user choice)
    gtag('consent', 'default', {
      'analytics_storage': 'denied',
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'wait_for_update': 500
    });
  </script>

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4997003296069618" crossorigin="anonymous"></script>

  <!-- Floating bubbles: CSS-only, no JS -->
  <style>
    /* z-index:-1 renders between the canvas background and page content.
       prefers-reduced-motion in global.css disables all animations globally. */
    .bubbles-bg {
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      overflow: hidden;      /* clips bubbles at viewport edges — prevents horizontal scroll */
    }
    .bubble {
      position: absolute;
      bottom: -200px;        /* start off-screen below */
      --op: .06;             /* default opacity (overridden per-bubble) */
    }
    .bubble img { display: block; width: 100%; height: auto; }

    @keyframes bubble-rise-r {
      0%   { transform: translateY(0) translateX(0);    opacity: 0; }
      8%   { opacity: var(--op); }
      92%  { opacity: var(--op); }
      100% { transform: translateY(-120vh) translateX(20px); opacity: 0; }
    }
    @keyframes bubble-rise-l {
      0%   { transform: translateY(0) translateX(0);     opacity: 0; }
      8%   { opacity: var(--op); }
      92%  { opacity: var(--op); }
      100% { transform: translateY(-120vh) translateX(-20px); opacity: 0; }
    }

    /* Color cycle: green accent → gray → green, ease-in-out for smooth transition */
    @keyframes color-cycle {
      0%   { filter: saturate(1.4); }
      50%  { filter: grayscale(1);  }
      100% { filter: saturate(1.4); }
    }

    /* 8 bubbles — sizes 200–500px, opacity 14–17%, two independent animations each */
    .b1 { width:280px; left: 4%;  --op:.15; animation:bubble-rise-r 22s   0s linear      infinite, color-cycle 35s   0s ease-in-out infinite; }
    .b2 { width:220px; left:22%;  --op:.16; animation:bubble-rise-l 18s  -8s linear      infinite, color-cycle 38s -12s ease-in-out infinite; }
    .b3 { width:460px; left:38%;  --op:.14; animation:bubble-rise-r 28s -15s linear      infinite, color-cycle 32s -25s ease-in-out infinite; }
    .b4 { width:240px; left:62%;  --op:.15; animation:bubble-rise-l 20s  -5s linear      infinite, color-cycle 40s  -7s ease-in-out infinite; }
    .b5 { width:380px; left:72%;  --op:.14; animation:bubble-rise-r 25s -12s linear      infinite, color-cycle 36s -18s ease-in-out infinite; }
    .b6 { width:200px; left:13%;  --op:.17; animation:bubble-rise-l 16s -20s linear      infinite, color-cycle 33s -30s ease-in-out infinite; }
    .b7 { width:500px; left:44%;  --op:.14; animation:bubble-rise-r 30s  -3s linear      infinite, color-cycle 37s  -4s ease-in-out infinite; }
    .b8 { width:320px; left:30%;  --op:.16; animation:bubble-rise-l 19s  -9s linear      infinite, color-cycle 34s -22s ease-in-out infinite; }
  </style>

  <!-- Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Yasir Aljiyadi",
    "alternateName": "ياسر الجيادي",
    "url": "https://yasiraboanmar.com",
    "image": "https://yasiraboanmar.com/Yasir-Aljiyadi-photo.png",
    "jobTitle": "HR Leader",
    "sameAs": [
      "https://x.com/Yasir_Aljiyadi",
      "https://www.linkedin.com/in/yasir-aljiyadi-21b514160/",
      "https://github.com/yasiraboomar"
    ]
  }
  </script>

</head>
<body>
  <div class="bubbles-bg" aria-hidden="true">
    <div class="bubble b1"><img src="/YasirAboAnmar.svg" alt="" /></div>
    <div class="bubble b2"><img src="/YasirAboAnmar.svg" alt="" /></div>
    <div class="bubble b3"><img src="/YasirAboAnmar.svg" alt="" /></div>
    <div class="bubble b4"><img src="/YasirAboAnmar.svg" alt="" /></div>
    <div class="bubble b5"><img src="/YasirAboAnmar.svg" alt="" /></div>
    <div class="bubble b6"><img src="/YasirAboAnmar.svg" alt="" /></div>
    <div class="bubble b7"><img src="/YasirAboAnmar.svg" alt="" /></div>
    <div class="bubble b8"><img src="/YasirAboAnmar.svg" alt="" /></div>
  </div>
  <slot />
  <CookieConsent lang={lang} />
</body>
</html>
