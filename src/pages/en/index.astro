---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import homeData from '../../data/home-en.json';
import ArticleCard from '../../components/ArticleCard.astro';

const posts = (await getCollection('blog_en', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const currentPath = Astro.url.pathname;
const { meta, hero, stats, about, skills, contact } = homeData;
---

<Base
  title={meta.title}
  description={meta.description}
  lang="en"
  dir="ltr"
>
  <Navbar lang="en" currentPath={currentPath} />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <img
          class="hero-photo"
          src={hero.photo}
          alt={hero.name_en}
          width="180" height="180"
          loading="eager"
        />
        <div class="hero-body">
          <div class="hero-tag">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor"><circle cx="6" cy="6" r="6"/></svg>
            {hero.badge}
          </div>
          <h1 class="hero-name">
            <span class="en">{hero.name_en}</span>
            <span class="ar" style="font-size:.6em; color:var(--muted);">{hero.name_ar}</span>
          </h1>
          <p class="hero-sub">{hero.subtitle}</p>
          <p class="hero-lead">{hero.lead}</p>
          <div class="hero-cta">
            <a class="btn btn-primary" href="/en/blog/">Read the Blog</a>
            <a class="btn btn-ghost" href={hero.cv_file} download>Download CV</a>
            <a class="btn btn-outline" href={`mailto:${hero.email}`}>Contact</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container"><hr class="divider" /></div>

  <!-- Stats Panel -->
  <section class="section" style="padding-top:40px;">
    <div class="container">
      <div class="stats-panel">
        {stats.map((stat, i) => (
          <div class={`stats-panel-item${i === 0 ? ' stats-panel-hero' : ''}`}>
            <div class="stat-num">{stat.number}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="container"><hr class="divider" /></div>

  <!-- About -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">About</span>
        <h2 class="section-title">Who I Am</h2>
      </div>
      <div class="about-grid">
        {about.map(item => (
          <div class="card" style="display:flex; gap:12px; align-items:flex-start;">
            <svg style="flex-shrink:0; margin-top:3px;" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="7.5" stroke="var(--accent-border)"/>
              <path d="M5 8l2 2 4-4" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span style="font-size:.95rem; color:var(--muted);">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="container"><hr class="divider" /></div>

  <!-- Skills -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Expertise</span>
        <h2 class="section-title">Skills & Experience</h2>
      </div>
      <div class="skills-grid">
        {skills.map((group, gi) => (
          <div class="skill-group">
            <h4>{group.title}</h4>
            <div class="skill-chips">
              {group.chips.map(c => (
                <span class={`skill-chip${gi === skills.length - 1 ? ' skill-chip-dim' : ''}`}>{c}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="container"><hr class="divider" /></div>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header" style="display:flex; align-items:flex-end; justify-content:space-between; flex-wrap:wrap; gap:12px;">
          <div>
            <span class="section-label">Blog</span>
            <h2 class="section-title" style="margin-bottom:0;">Latest Articles</h2>
          </div>
          <a class="btn btn-ghost" href="/en/blog/">All Articles →</a>
        </div>
        <div class="blog-grid">
          {posts.map(post => (
            <ArticleCard
              href={`/en/blog/${post.id}/`}
              title={post.data.title}
              description={post.data.description}
              cover={post.data.cover}
              tags={post.data.tags}
              pubDate={post.data.pubDate}
              body={post.body}
              lang="en"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <div class="container"><hr class="divider" /></div>

  <!-- Contact -->
  <section class="section">
    <div class="container" style="max-width:560px;">
      <div class="section-header">
        <span class="section-label">Contact</span>
        <h2 class="section-title">{contact.title}</h2>
        <p class="section-desc">{contact.description}</p>
      </div>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a class="btn btn-primary" href={`mailto:${contact.email}`}>Send Email</a>
        <a class="btn btn-outline" href={contact.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a class="btn btn-outline" href={contact.vcf_file} download>Save Contact</a>
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Base>
