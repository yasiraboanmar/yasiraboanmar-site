---
import Base from '../../../layouts/Base.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_MAP_EN, getCategory } from '../../../utils/blog';
import ArticleCard from '../../../components/ArticleCard.astro';

const allPosts = (await getCollection('blog_en', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const seenLabels = new Set<string>();
const activeCategories = allPosts
  .map(p => getCategory(p.data.tags, CATEGORY_MAP_EN))
  .filter((c): c is NonNullable<typeof c> => {
    if (!c || seenLabels.has(c.label)) return false;
    seenLabels.add(c.label);
    return true;
  });

const currentPath = Astro.url.pathname;
const [latestPost, ...restPosts] = allPosts;
---

<Base
  title="Blog — Yasir Aljiyadi"
  description="Weekly articles on HR: payroll, governance, Saudi labor law, and HR technology."
  lang="en"
  dir="ltr"
>
  <Navbar lang="en" currentPath={currentPath} />

  <div class="page-header">
    <div class="container">
      <span class="section-label">Blog</span>
      <h1 style="margin-bottom:12px;">HR Articles</h1>
      <p style="color:var(--muted); max-width:52ch; font-size:1.05rem;">
        Specialized articles on payroll, governance, compliance, and HR technology in the Saudi market.
        A new article every week.
      </p>

      {activeCategories.length > 0 && (
        <div class="cat-filter" style="margin-top:28px;" role="group" aria-label="Filter by category">
          <button class="cat-btn active" data-filter="all"
                  aria-pressed="true">All</button>
          {activeCategories.map(cat => (
            <button class="cat-btn" data-filter={cat.label}
                    style={`--cat-color:${cat.color}`}
                    aria-pressed="false">
              {cat.label}
            </button>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="container" style="padding-bottom:80px;">
    {allPosts.length === 0 ? (
      <div style="text-align:center; padding:80px 0; color:var(--muted);">
        <p style="font-size:1.1rem;">No articles yet. Coming soon...</p>
      </div>
    ) : (
      <div class="blog-grid">

        {/* Latest post — wide card */}
        {latestPost && (
          <ArticleCard
            variant="wide"
            href={`/en/blog/${latestPost.id}/`}
            title={latestPost.data.title}
            description={latestPost.data.description}
            cover={latestPost.data.cover}
            tags={latestPost.data.tags}
            pubDate={latestPost.data.pubDate}
            body={latestPost.body}
            lang="en"
          />
        )}

        {/* Rest of posts */}
        {restPosts.map(post => (
          <ArticleCard
            href={`/en/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            cover={post.data.cover}
            tags={post.data.tags}
            pubDate={post.data.pubDate}
            body={post.body}
            lang="en"
          />
        ))}

      </div>
    )}
  </div>

  <Footer lang="en" />
</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const cards = document.querySelectorAll<HTMLElement>('[data-category]');

  btns.forEach(btn => btn.addEventListener('click', () => {
    btns.forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');

    const f = btn.dataset.filter;
    cards.forEach(c => {
      c.style.display = (f === 'all' || c.dataset.category === f) ? '' : 'none';
    });
  }));
</script>
