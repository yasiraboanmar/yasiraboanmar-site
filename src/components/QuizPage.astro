---
import Base from '../layouts/Base.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

export interface Props {
  lang: 'ar' | 'en';
  quiz: {
    slug: string;
    title: string;
    description: string;
    audience: string;
    total_questions: number;
    questions: Array<{
      question: string;
      options: string[];
      correct: number;
      hint?: string;
      difficulty?: string;
      reference?: string;
    }>;
  };
  currentPath: string;
  image?: string;
}

const { lang, quiz, currentPath, image } = Astro.props;
const isAr = lang === 'ar';
const dir = isAr ? 'rtl' : 'ltr';

const quizzesIndexPath = isAr ? '/quizzes/' : '/en/quizzes/';

const quizPath      = isAr ? `/quizzes/${quiz.slug}/` : `/en/quizzes/${quiz.slug}/`;
const quizFullUrl   = `https://yasiraboanmar.com${quizPath}`;
const inviteText    = isAr
  ? `اختبر معرفتك في اختبار «${quiz.title}» على نظام العمل السعودي — yasiraboanmar.com${quizPath}`
  : `Test your knowledge with the "${quiz.title}" quiz on Saudi Labor Law — yasiraboanmar.com${quizPath}`;
const inviteWaUrl   = `https://api.whatsapp.com/send?text=${encodeURIComponent(inviteText)}`;
const inviteXUrl    = `https://twitter.com/intent/tweet?text=${encodeURIComponent(inviteText)}`;
const inviteLiUrl   = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(quizFullUrl)}`;

const ui = {
  audience:      isAr ? 'الجمهور المستهدف' : 'Target audience',
  totalQ:        isAr ? 'عدد الأسئلة' : 'Questions',
  start:         isAr ? 'ابدأ الاختبار' : 'Start Quiz',
  backToList:    isAr ? '← جميع الاختبارات' : '← All Quizzes',
  questionOf:    isAr ? 'من' : 'of',
  question:      isAr ? 'السؤال' : 'Question',
  showHint:      isAr ? 'تلميح' : 'Hint',
  hideHint:      isAr ? 'إخفاء التلميح' : 'Hide hint',
  reference:     isAr ? 'المرجع:' : 'Reference:',
  correct:       isAr ? 'إجابة صحيحة' : 'Correct',
  wrong:         isAr ? 'إجابة خاطئة' : 'Wrong',
  next:          isAr ? 'التالي' : 'Next',
  seeResult:     isAr ? 'عرض النتيجة' : 'See Result',
  regTitle:      isAr ? 'أضِف اسمك لتخصيص نتيجتك (اختياري)' : 'Personalize your result (optional)',
  regSubtitle:   isAr ? 'لا يلزمك الإدخال لعرض النتيجة' : 'Not required to view your result',
  namePH:        isAr ? 'الاسم' : 'Your name',
  emailPH:       isAr ? 'البريد الإلكتروني' : 'Email address',
  emailHint:     isAr ? 'لإرسال نسخة من نتيجتك إليك' : 'To receive a copy of your result',
  showResult:    isAr ? 'اعرض نتيجتي' : 'Show My Result',
  skip:          isAr ? 'تخطّ' : 'Skip',
  yourScore:     isAr ? 'نتيجتك' : 'Your Score',
  correctAns:    isAr ? 'إجابات صحيحة' : 'correct answers',
  yourRating:    isAr ? 'تقييمك' : 'Your Rating',
  printBtn:      isAr ? 'طباعة الشهادة' : 'Print Certificate',
  emailBtn:      isAr ? 'أرسل لي النتيجة' : 'Email me my result',
  retake:        isAr ? 'أعِد الاختبار' : 'Retake Quiz',
  sending:       isAr ? 'جارٍ الإرسال...' : 'Sending...',
  sent:          isAr ? 'تم الإرسال!' : 'Sent!',
  sendError:     isAr ? 'فشل الإرسال، حاول لاحقاً' : 'Failed to send, please try again',
  diffEasy:      isAr ? 'سهل' : 'Easy',
  diffMedium:    isAr ? 'متوسط' : 'Medium',
  diffHard:      isAr ? 'صعب' : 'Hard',
  certAnon:      isAr ? 'مشارك' : 'Participant',
  certCompleted: isAr ? 'عن إتمام اختبار' : 'for completing the quiz',
  certSucc:      isAr ? 'بنجاح' : 'successfully',
  copied:        isAr ? 'تم النسخ!' : 'Copied!',
  grades: {
    excellent: { label: isAr ? 'ممتاز'    : 'Excellent',   color: '#9ee6cf', bg: 'rgba(158,230,207,.1)', sealColor: '#b8912f', sealBg: 'rgba(184,145,47,.08)',  msg: isAr ? 'رائع! تمتلك معرفة استثنائية بنظام العمل السعودي. أنت نموذج يُحتذى به.'                                     : "Outstanding! Your knowledge of Saudi labor law is exceptional. You're a true role model." },
    veryGood:  { label: isAr ? 'جيد جداً' : 'Very Good',   color: '#5bb8d4', bg: 'rgba(91,184,212,.1)',  sealColor: '#3f8f74', sealBg: 'rgba(63,143,116,.08)',   msg: isAr ? 'أداء ممتاز! أنت على طريق الاحتراف. مراجعة بسيطة للنقاط التي فاتتك ستجعلك خبيراً كاملاً.' : 'Great job! You\'re on the path to mastery. Reviewing the missed points will make you a full expert.' },
    good:      { label: isAr ? 'جيد'       : 'Good',        color: '#e8c07a', bg: 'rgba(232,192,122,.1)', sealColor: '#e8c07a', sealBg: 'rgba(232,192,122,.08)', msg: isAr ? 'جيد! أنت تعرف الأساسيات. تصفح مقالاتنا لتعزيز معرفتك وترقية مستواك.'                                      : 'Good effort! You know the basics. Browse our articles to deepen your knowledge.' },
    acceptable:{ label: isAr ? 'مقبول'    : 'Acceptable',  color: '#f4a261', bg: 'rgba(244,162,97,.1)',  sealColor: '#f4a261', sealBg: 'rgba(244,162,97,.08)',  msg: isAr ? 'المعرفة بنظام العمل تحمي حقوقك. استثمر وقتاً في قراءة مقالاتنا لتحسين نتيجتك.'                       : 'Knowledge of labor law protects your rights. Invest time in our articles to improve.' },
    weak:      { label: isAr ? 'ضعيف'     : 'Weak',        color: '#e07070', bg: 'rgba(224,112,112,.1)', sealColor: '#e07070', sealBg: 'rgba(224,112,112,.08)', msg: isAr ? 'لا بأس، الجميع يبدأ من مكان ما! تصفح مقالاتنا عن نظام العمل وستتفاجأ بتحسّنك.'                       : 'Everyone starts somewhere! Browse our labor law articles and you\'ll be amazed at your progress.' },
  },
};

const quizDataStr = JSON.stringify(quiz);
const uiDataStr   = JSON.stringify(ui);
---

<Base
  title={`${quiz.title} — ${isAr ? 'ياسر الجيادي' : 'Yasir Aljiyadi'}`}
  description={quiz.description}
  image={image}
  lang={lang}
  dir={dir}
>
  <Navbar lang={lang} currentPath={currentPath} />

  <main class="quiz-wrap" id="quiz-app">

    <!-- ═══ START SCREEN ═══ -->
    <div id="screen-start" class="quiz-screen section">
      <div class="container" style="max-width:700px;">
        <a href={quizzesIndexPath} class="quiz-back-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13 8H3M7 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {ui.backToList}
        </a>

        <div class="quiz-start-card card">
          <div class="quiz-start-meta">
            <span class="section-label">{isAr ? 'اختبار تفاعلي' : 'Interactive Quiz'}</span>
          </div>
          <h1 class="quiz-start-title">{quiz.title}</h1>
          <p class="quiz-start-desc">{quiz.description}</p>
          <div class="quiz-start-info">
            <div class="quiz-info-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="quiz-info-label">{ui.audience}:</span>
              <span>{quiz.audience}</span>
            </div>
            <div class="quiz-info-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span class="quiz-info-label">{ui.totalQ}:</span>
              <span>{quiz.total_questions} {isAr ? 'سؤال' : 'questions'}</span>
            </div>
          </div>
          <button id="btn-start" class="btn btn-primary" style="font-size:1.05rem; padding:14px 32px;">
            {ui.start}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>

          <div class="quiz-invite">
            <p class="quiz-invite-lbl">{isAr ? 'شارك الاختبار مع الآخرين:' : 'Invite others to take this quiz:'}</p>
            <div class="quiz-invite-btns">
              <button id="invite-share-btn" class="btn btn-outline quiz-invite-btn" type="button">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                {isAr ? 'شارك الاختبار' : 'Share this quiz'}
              </button>
              <button id="invite-copy-btn" class="btn btn-outline quiz-invite-btn" type="button">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                <span id="invite-copy-lbl">{isAr ? 'نسخ الرابط' : 'Copy link'}</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ QUIZ SCREEN ═══ -->
    <div id="screen-quiz" class="quiz-screen section" hidden>
      <div class="container" style="max-width:700px;">

        <!-- Segmented progress -->
        <div class="quiz-progress-wrap">
          <div class="quiz-progress-label">
            <span id="q-label">{isAr ? 'السؤال 1' : 'Question 1'}</span>
          </div>
          <div class="quiz-segs" id="progress-segs"></div>
        </div>

        <!-- Question Card -->
        <div class="quiz-question-card card">
          <div class="quiz-question-header">
            <span class="quiz-diff-badge" id="diff-badge"></span>
          </div>
          <p class="quiz-question-text" id="question-text"></p>

          <!-- Options -->
          <div class="quiz-opts" id="options-container"></div>

          <!-- Hint (collapsible dotted box) -->
          <div class="hint-wrap" id="hint-wrap" hidden>
            <button class="hint-toggle" id="hint-btn" type="button">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span id="hint-btn-label">{ui.showHint}</span>
            </button>
            <p class="hint-body" id="hint-text" hidden></p>
          </div>

          <!-- Feedback (shown after answer) -->
          <div class="quiz-feedback" id="feedback" hidden>
            <div class="quiz-fb-result" id="feedback-result"></div>
            <p class="quiz-fb-ref" id="feedback-ref"></p>
          </div>

          <!-- Next button -->
          <button class="btn btn-primary quiz-next-btn" id="btn-next" hidden>
            <span id="btn-next-label">{ui.next}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>

      </div>
    </div>

    <!-- ═══ REGISTER SCREEN ═══ -->
    <div id="screen-register" class="quiz-screen section" hidden>
      <div class="container" style="max-width:520px;">
        <div class="quiz-register-card card">
          <div class="quiz-register-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h2 class="quiz-register-title">{ui.regTitle}</h2>
          <p class="quiz-register-sub">{ui.regSubtitle}</p>
          <form id="register-form" autocomplete="on">
            <div class="quiz-field">
              <input type="text"  id="input-name"  name="name"  placeholder={ui.namePH}  autocomplete="name"  class="quiz-input" />
            </div>
            <div class="quiz-field">
              <input type="email" id="input-email" name="email" placeholder={ui.emailPH} autocomplete="email" class="quiz-input" />
              <p class="quiz-field-hint">{ui.emailHint}</p>
            </div>
            <div class="quiz-register-actions">
              <button type="submit" class="btn btn-primary" style="flex:1;">{ui.showResult}</button>
              <button type="button" id="btn-skip" class="btn btn-ghost">{ui.skip}</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- ═══ RESULT SCREEN ═══ -->
    <div id="screen-result" class="quiz-screen section" hidden>
      <div class="container" style="max-width:600px;">

        <div class="result-wrap">
          <!-- Glow layer (activated for excellent / veryGood) -->
          <div class="result-glow" id="result-glow"></div>

          <div class="quiz-result-card card" id="result-card">
            <!-- Seal -->
            <div class="result-seal-wrap">
              <div class="result-seal" id="result-seal">
                <span class="result-seal-lbl" id="result-seal-label"></span>
              </div>
            </div>

            <div class="quiz-result-name" id="result-name" hidden></div>

            <div class="quiz-result-score">
              <span class="quiz-score-num" id="score-num"></span>
              <span class="quiz-score-sep"> / </span>
              <span class="quiz-score-total" id="score-total"></span>
            </div>
            <div class="quiz-score-percent" id="score-percent"></div>

            <p class="quiz-result-msg" id="result-msg"></p>
          </div>
        </div>

        <!-- Share buttons -->
        <div class="quiz-share no-print">
          <p class="quiz-share-label">{isAr ? 'شارك نتيجتك:' : 'Share your result:'}</p>
          <div class="quiz-share-btns">
            <button id="share-wa" class="btn btn-outline" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.997 2C6.477 2 2 6.477 2 12c0 1.99.554 3.847 1.515 5.434L2 22l4.728-1.485A9.953 9.953 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 11.997 2zm0 18.182a8.167 8.167 0 01-4.164-1.13l-.298-.177-3.086.81.823-3.012-.194-.31A8.143 8.143 0 013.818 12c0-4.51 3.67-8.182 8.179-8.182 4.509 0 8.18 3.672 8.18 8.182s-3.671 8.182-8.18 8.182z"/></svg>
              {isAr ? 'واتساب' : 'WhatsApp'}
            </button>
            <button id="share-x" class="btn btn-outline" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X
            </button>
            <button id="share-copy" class="btn btn-outline" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span id="share-copy-lbl">{isAr ? 'نسخ الرابط' : 'Copy link'}</span>
            </button>
            {quiz.slug === 'hr-specialists' && (
              <button id="share-li" class="btn btn-outline" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5c0 1.38-1.12 2.5-2.5 2.5S0 4.88 0 3.5C0 2.12 1.12 1 2.48 1c1.37 0 2.5 1.12 2.5 2.5zM.5 8.5h4V23h-4V8.5zm7 0h3.83v1.98h.05c.53-1 1.82-2.06 3.75-2.06 4.01 0 4.75 2.64 4.75 6.07V23h-4v-5.91c0-1.41-.03-3.22-1.96-3.22-1.96 0-2.26 1.53-2.26 3.12V23h-4V8.5z"/></svg>
                LinkedIn
              </button>
            )}
          </div>
        </div>

        <!-- Action buttons -->
        <div class="quiz-result-actions no-print">
          <button id="btn-print" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            {ui.printBtn}
          </button>
          <button id="btn-email" class="btn btn-outline" hidden>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span id="email-btn-label">{ui.emailBtn}</span>
          </button>
          <button id="btn-retake" class="btn btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
            {ui.retake}
          </button>
          <a href={quizzesIndexPath} class="btn btn-ghost">{ui.backToList}</a>
        </div>

      </div>
    </div>

  </main>

  <!-- ═══ PRINT CERTIFICATE (outside main, shown only in @media print) ═══ -->
  <div class="cert-print" id="cert-print" aria-hidden="true">
    <div class="cert-frame"></div>
    <div class="cert-content">
      <div class="cert-site-mark">
        <img src="/YAA.svg" alt={isAr ? 'ياسر الجيادي' : 'Yasir Aljiyadi'} class="cert-logo-img" />
        <span class="cert-domain">yasiraboanmar.com</span>
      </div>

      <div class="cert-eyebrow">{isAr ? 'شهادة اجتياز اختبار' : 'Certificate of Completion'}</div>
      <h2 class="cert-title-el" id="cert-title">{quiz.title}</h2>
      <div class="cert-subtitle">{isAr ? 'Certificate of Completion' : 'شهادة اجتياز اختبار'}</div>

      <div class="cert-grants">{isAr ? 'تُمنح هذه الشهادة إلى' : 'This certificate is awarded to'}</div>
      <div class="cert-pname" id="cert-name"></div>
      <div class="cert-completed" id="cert-quiz-completed"></div>

      <div class="cert-score-row">
        <div class="cert-score-block">
          <div class="cert-score-num" id="cert-score"></div>
          <div class="cert-score-lbl">{isAr ? 'النتيجة' : 'Score'}</div>
        </div>
        <div class="cert-dv"></div>
        <div class="cert-seal" id="cert-seal-print">
          <span class="cert-seal-lbl" id="cert-seal-label-print"></span>
        </div>
        <div class="cert-dv"></div>
        <div class="cert-score-block">
          <div class="cert-score-num" id="cert-pct"></div>
          <div class="cert-score-lbl">{isAr ? 'النسبة' : 'Percentage'}</div>
        </div>
      </div>

      <p class="cert-quote" id="cert-quote"></p>

      <div class="cert-footer-row">
        <div class="cert-footer-item">
          <div class="cert-footer-val" id="cert-date"></div>
          <div>{isAr ? 'التاريخ' : 'Date'}</div>
        </div>
        <div class="cert-footer-item">
          <div class="cert-footer-val">yasiraboanmar.com</div>
          <div>{isAr ? 'المصدر' : 'Source'}</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Embedded data for JS -->
  <script id="quiz-data" type="application/json" set:html={quizDataStr}></script>
  <script id="ui-data"   type="application/json" set:html={uiDataStr}></script>
  <script id="quiz-meta" type="application/json" set:html={JSON.stringify({ lang, quizzesIndexPath })}></script>

  <script is:inline>
  (function () {
    const quiz = JSON.parse(document.getElementById('quiz-data').textContent);
    const ui   = JSON.parse(document.getElementById('ui-data').textContent);
    const meta = JSON.parse(document.getElementById('quiz-meta').textContent);
    const isAr = meta.lang === 'ar';

    const LETTERS_AR = ['أ', 'ب', 'ج', 'د'];
    const LETTERS_EN = ['A', 'B', 'C', 'D'];
    const letters    = isAr ? LETTERS_AR : LETTERS_EN;

    // ── State ──────────────────────────────────────────────────────────────
    let currentQ  = 0;
    let score     = 0;
    let answered  = false;
    let hintOpen  = false;
    let userName  = '';
    let userEmail = '';

    // ── Screens ─────────────────────────────────────────────────────────────
    const screens = {
      start:    document.getElementById('screen-start'),
      quiz:     document.getElementById('screen-quiz'),
      register: document.getElementById('screen-register'),
      result:   document.getElementById('screen-result'),
    };

    function showScreen(name) {
      Object.values(screens).forEach(s => { if (s) s.hidden = true; });
      if (screens[name]) screens[name].hidden = false;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ── Helpers ─────────────────────────────────────────────────────────────
    function difficultyLabel(d) {
      if (!d) return '';
      if (isAr) return d;
      const map = { 'سهل': ui.diffEasy, 'متوسط': ui.diffMedium, 'صعب': ui.diffHard };
      return map[d] || d;
    }

    function difficultyClass(d) {
      const map = { 'سهل': 'easy', 'Easy': 'easy', 'متوسط': 'medium', 'Medium': 'medium', 'صعب': 'hard', 'Hard': 'hard' };
      return map[d] || 'medium';
    }

    function getGradeKey(pct) {
      if (pct >= 89) return 'excellent';
      if (pct >= 75) return 'veryGood';
      if (pct >= 60) return 'good';
      if (pct >= 45) return 'acceptable';
      return 'weak';
    }

    // ── Segmented progress ───────────────────────────────────────────────────
    function renderSegments(currentIdx, total) {
      const segs = document.getElementById('progress-segs');
      segs.innerHTML = '';
      for (let i = 0; i < total; i++) {
        const s = document.createElement('div');
        s.className = 'q-seg' + (i < currentIdx ? ' done' : i === currentIdx ? ' active' : '');
        segs.appendChild(s);
      }
      const lbl = isAr
        ? 'السؤال ' + (currentIdx + 1) + ' من ' + total
        : 'Question ' + (currentIdx + 1) + ' of ' + total;
      document.getElementById('q-label').textContent = lbl;
    }

    // ── Render Question ──────────────────────────────────────────────────────
    function renderQuestion(idx) {
      answered = false;
      hintOpen = false;
      const q     = quiz.questions[idx];
      const total = quiz.questions.length;

      renderSegments(idx, total);

      // Difficulty badge
      const badge = document.getElementById('diff-badge');
      if (q.difficulty) {
        badge.textContent = difficultyLabel(q.difficulty);
        badge.className   = 'quiz-diff-badge diff-' + difficultyClass(q.difficulty);
        badge.hidden      = false;
      } else {
        badge.hidden = true;
      }

      document.getElementById('question-text').textContent = q.question;

      // Options with letter badges
      const container = document.getElementById('options-container');
      container.innerHTML = '';
      q.options.forEach(function(opt, i) {
        const btn = document.createElement('button');
        btn.type      = 'button';
        btn.className = 'quiz-opt';

        const ltr = document.createElement('span');
        ltr.className   = 'opt-ltr';
        ltr.textContent = letters[i] || String(i + 1);

        const txt = document.createElement('span');
        txt.className   = 'opt-txt';
        txt.textContent = opt;

        btn.appendChild(ltr);
        btn.appendChild(txt);
        btn.addEventListener('click', function() { selectAnswer(i); });
        container.appendChild(btn);
      });

      // Hint
      const hintWrap = document.getElementById('hint-wrap');
      if (q.hint) {
        hintWrap.hidden = false;
        document.getElementById('hint-text').hidden    = true;
        document.getElementById('hint-text').textContent = q.hint;
        document.getElementById('hint-btn-label').textContent = ui.showHint;
        hintOpen = false;
      } else {
        hintWrap.hidden = true;
      }

      document.getElementById('feedback').hidden  = true;
      document.getElementById('btn-next').hidden  = true;
    }

    // ── Select Answer ────────────────────────────────────────────────────────
    function selectAnswer(chosen) {
      if (answered) return;
      answered = true;

      const q       = quiz.questions[currentQ];
      const correct = q.correct;
      const isRight = chosen === correct;
      if (isRight) score++;

      const options = document.querySelectorAll('.quiz-opt');
      options.forEach(function(btn, i) {
        btn.disabled = true;
        if (i === correct)     btn.classList.add('opt-correct');
        else if (i === chosen) btn.classList.add('opt-wrong');
        else                   btn.classList.add('opt-dim');
      });

      const feedback = document.getElementById('feedback');
      feedback.hidden = false;
      const resultEl  = document.getElementById('feedback-result');
      resultEl.textContent = isRight ? ('✓ ' + ui.correct) : ('✗ ' + ui.wrong);
      resultEl.className   = 'quiz-fb-result ' + (isRight ? 'fb-correct' : 'fb-wrong');

      const refEl = document.getElementById('feedback-ref');
      if (q.reference) {
        refEl.textContent = ui.reference + ' ' + q.reference;
        refEl.hidden = false;
      } else {
        refEl.hidden = true;
      }

      const btnNext = document.getElementById('btn-next');
      const isLast  = currentQ === quiz.questions.length - 1;
      btnNext.hidden = false;
      document.getElementById('btn-next-label').textContent = isLast ? ui.seeResult : ui.next;
    }

    // ── Next ─────────────────────────────────────────────────────────────────
    document.getElementById('btn-next').addEventListener('click', function() {
      const isLast = currentQ === quiz.questions.length - 1;
      if (isLast) {
        showScreen('register');
      } else {
        currentQ++;
        renderQuestion(currentQ);
      }
    });

    // ── Hint toggle ──────────────────────────────────────────────────────────
    document.getElementById('hint-btn').addEventListener('click', function() {
      hintOpen = !hintOpen;
      document.getElementById('hint-text').hidden = !hintOpen;
      document.getElementById('hint-btn-label').textContent = hintOpen ? ui.hideHint : ui.showHint;
    });

    // ── Start ────────────────────────────────────────────────────────────────
    document.getElementById('btn-start').addEventListener('click', function() {
      currentQ = 0; score = 0;
      showScreen('quiz');
      renderQuestion(0);
    });

    // ── Invite share + copy (start screen) ───────────────────────────────────
    var _inviteUrl  = 'https://yasiraboanmar.com' + (isAr ? '/quizzes/' : '/en/quizzes/') + quiz.slug + '/';
    var _inviteTxt  = isAr
      ? 'اختبر معرفتك في اختبار «' + quiz.title + '» على نظام العمل السعودي'
      : 'Test your knowledge with the "' + quiz.title + '" quiz on Saudi Labor Law';
    var _quizImgs   = ['/images/quizzes/law-quiz-1.png', '/images/quizzes/law-quiz-2.png', '/images/quizzes/law-quiz-3.png'];

    var inviteShareBtn = document.getElementById('invite-share-btn');
    if (inviteShareBtn) {
      inviteShareBtn.addEventListener('click', async function() {
        var imgPath = _quizImgs[Math.floor(Math.random() * _quizImgs.length)];
        try {
          var res  = await fetch(imgPath);
          var blob = await res.blob();
          var file = new File([blob], 'quiz.jpg', { type: blob.type });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({ files: [file], text: _inviteTxt });
            return;
          }
        } catch (e) {
          if (e.name === 'AbortError') return;
        }
        if (navigator.share) {
          navigator.share({ text: _inviteTxt + '\n' + _inviteUrl }).catch(function() {});
        } else {
          window.open('https://api.whatsapp.com/send?text=' + encodeURIComponent(_inviteTxt + '\n' + _inviteUrl), '_blank', 'noopener');
        }
      });
    }

    var inviteCopyBtn = document.getElementById('invite-copy-btn');
    if (inviteCopyBtn) {
      inviteCopyBtn.addEventListener('click', function() {
        var lbl  = document.getElementById('invite-copy-lbl');
        var orig = lbl.textContent;
        navigator.clipboard.writeText(_inviteUrl).then(function() {
          lbl.textContent = ui.copied;
          setTimeout(function() { lbl.textContent = orig; }, 1800);
        }).catch(function() {});
      });
    }

    // ── Register form ────────────────────────────────────────────────────────
    document.getElementById('register-form').addEventListener('submit', function(e) {
      e.preventDefault();
      userName  = document.getElementById('input-name').value.trim();
      userEmail = document.getElementById('input-email').value.trim();
      showResult();
    });

    document.getElementById('btn-skip').addEventListener('click', function() {
      userName = ''; userEmail = '';
      showResult();
    });

    // ── Confetti ──────────────────────────────────────────────────────────────
    function launchConfetti() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var colors = ['#9ee6cf', '#e8c07a', '#5bb8d4', '#f4a261', '#b8e6a4', '#f0c060'];
      var wrap   = document.createElement('div');
      wrap.className = 'confetti-wrap';
      document.body.appendChild(wrap);
      for (var i = 0; i < 60; i++) {
        var p = document.createElement('div');
        p.className = 'confetti-piece';
        p.style.cssText = [
          'left:' + (Math.random() * 100) + '%',
          'background:' + colors[i % colors.length],
          'width:' + (4 + Math.random() * 6) + 'px',
          'height:' + (8 + Math.random() * 8) + 'px',
          'animation-delay:' + (Math.random() * 2.5) + 's',
          'animation-duration:' + (2.5 + Math.random() * 2) + 's',
          'border-radius:' + (Math.random() > 0.5 ? '50%' : '2px'),
        ].join(';');
        wrap.appendChild(p);
      }
      setTimeout(function() { if (wrap.parentNode) wrap.parentNode.removeChild(wrap); }, 7000);
    }

    // ── Show Result ───────────────────────────────────────────────────────────
    function showResult() {
      const total    = quiz.questions.length;
      const pct      = Math.round((score / total) * 100);
      const gradeKey = getGradeKey(pct);
      const grade    = ui.grades[gradeKey];

      // Determine celebration level
      const celebLevel = gradeKey === 'excellent' ? 'full' : gradeKey === 'veryGood' ? 'medium' : 'none';

      // Result card styling
      const card = document.getElementById('result-card');
      card.style.borderColor = grade.color;
      card.style.background  = grade.bg;

      // Seal
      const seal = document.getElementById('result-seal');
      seal.style.borderColor = grade.sealColor;
      seal.style.background  = grade.sealBg;
      const sealLbl = document.getElementById('result-seal-label');
      sealLbl.textContent = grade.label;
      sealLbl.style.color = grade.sealColor;

      // Glow + celebration
      const glow = document.getElementById('result-glow');
      if (celebLevel === 'full') {
        glow.className = 'result-glow glow-excellent';
        launchConfetti();
      } else if (celebLevel === 'medium') {
        glow.className = 'result-glow glow-veryGood';
        card.classList.add('flash-anim');
      } else {
        glow.className = 'result-glow';
      }

      // Name
      if (userName) {
        const nameEl = document.getElementById('result-name');
        nameEl.textContent = userName;
        nameEl.hidden      = false;
      }

      // Score
      document.getElementById('score-num').textContent     = score;
      document.getElementById('score-total').textContent   = total;
      document.getElementById('score-percent').textContent = pct + '%';
      document.getElementById('score-percent').style.color = grade.color;

      // Message
      document.getElementById('result-msg').textContent = grade.msg;

      // Email button
      if (userEmail) document.getElementById('btn-email').hidden = false;

      // Populate print certificate
      document.getElementById('cert-name').textContent = userName || ui.certAnon;
      document.getElementById('cert-score').textContent = score + '/' + total;
      document.getElementById('cert-pct').textContent   = pct + '%';
      document.getElementById('cert-seal-label-print').textContent = grade.label;
      document.getElementById('cert-quote').textContent = grade.msg;

      const completedTxt = isAr
        ? ui.certCompleted + ' «' + quiz.title + '» ' + ui.certSucc
        : ui.certCompleted + ' "' + quiz.title + '" ' + ui.certSucc;
      document.getElementById('cert-quiz-completed').textContent = completedTxt;

      const certDate = new Date().toLocaleDateString(
        isAr ? 'ar-SA' : 'en-US',
        { year: 'numeric', month: 'long', day: 'numeric' }
      );
      document.getElementById('cert-date').textContent = certDate;

      showScreen('result');

      // Share buttons
      var quizUrl = isAr
        ? 'https://yasiraboanmar.com/quizzes/' + quiz.slug + '/'
        : 'https://yasiraboanmar.com/en/quizzes/' + quiz.slug + '/';
      var shareTxt = isAr
        ? 'حصلت على ' + pct + '% في اختبار «' + quiz.title + '» — جرّب معرفتك على yasiraboanmar.com'
        : 'I scored ' + pct + '% on the "' + quiz.title + '" quiz — test your knowledge at yasiraboanmar.com';

      document.getElementById('share-wa').onclick = function() {
        window.open('https://api.whatsapp.com/send?text=' + encodeURIComponent(shareTxt + '\n' + quizUrl), '_blank', 'noopener');
      };
      document.getElementById('share-x').onclick = function() {
        window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareTxt) + '&url=' + encodeURIComponent(quizUrl), '_blank', 'noopener');
      };
      document.getElementById('share-copy').onclick = function() {
        var lbl = document.getElementById('share-copy-lbl');
        var orig = lbl.textContent;
        navigator.clipboard.writeText(quizUrl).then(function() {
          lbl.textContent = ui.copied;
          setTimeout(function() { lbl.textContent = orig; }, 1800);
        }).catch(function() {});
      };
      var liBtn = document.getElementById('share-li');
      if (liBtn) {
        liBtn.onclick = function() {
          window.open('https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(quizUrl), '_blank', 'noopener');
        };
      }

      // Save attempt to D1 (fire-and-forget)
      fetch('/api/quiz-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          quiz_id: quiz.slug,
          name: userName || null,
          email: userEmail || null,
          score: score,
          total_questions: total,
          percentage: pct,
          classification: gradeKey,
          lang: meta.lang,
        }),
      }).catch(function() {});
    }

    // ── Print ─────────────────────────────────────────────────────────────────
    document.getElementById('btn-print').addEventListener('click', function() { window.print(); });

    // ── Email ─────────────────────────────────────────────────────────────────
    document.getElementById('btn-email').addEventListener('click', async function() {
      const btn     = document.getElementById('btn-email');
      const labelEl = document.getElementById('email-btn-label');
      const total   = quiz.questions.length;
      const pct     = Math.round((score / total) * 100);
      const gradeKey = getGradeKey(pct);
      const grade    = ui.grades[gradeKey];

      labelEl.textContent = ui.sending;
      btn.disabled = true;

      try {
        const res = await fetch('/api/quiz-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            to_email: userEmail,
            name: userName || null,
            quiz_title: quiz.title,
            score: score,
            total_questions: total,
            percentage: pct,
            classification: grade.label,
            motivation: grade.msg,
            lang: meta.lang,
          }),
        });
        if (res.ok) {
          labelEl.textContent = ui.sent;
          btn.style.borderColor = 'var(--accent)';
          btn.style.color = 'var(--accent)';
        } else {
          throw new Error();
        }
      } catch (_) {
        labelEl.textContent = ui.sendError;
        btn.disabled = false;
      }
    });

    // ── Retake ────────────────────────────────────────────────────────────────
    document.getElementById('btn-retake').addEventListener('click', function() {
      currentQ = 0; score = 0; userName = ''; userEmail = '';
      const nameEl = document.getElementById('result-name');
      nameEl.hidden = true;
      nameEl.textContent = '';
      document.getElementById('btn-email').hidden = true;
      document.getElementById('email-btn-label').textContent = ui.emailBtn;
      document.getElementById('btn-email').disabled = false;
      document.getElementById('result-card').classList.remove('flash-anim');
      document.getElementById('result-glow').className = 'result-glow';
      document.getElementById('input-name').value  = '';
      document.getElementById('input-email').value = '';
      showScreen('quiz');
      renderQuestion(0);
    });
  })();
  </script>

  <Footer lang={lang} />
</Base>

<style is:global>
  /* ── Layout ─────────────────────────────────────────────────────────── */
  .quiz-wrap { min-height: 80vh; padding-top: 60px; }
  .quiz-screen { animation: fadeIn .25s ease; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }

  /* ── Back link ──────────────────────────────────────────────────────── */
  .quiz-back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--muted); font-size:.88rem; margin-bottom: 24px;
    font-family: var(--font); transition: color .15s;
  }
  .quiz-back-link:hover { color: var(--accent); text-decoration: none; }

  /* ── Start card ─────────────────────────────────────────────────────── */
  .quiz-start-card { padding: 36px; }
  .quiz-start-meta { margin-bottom: 12px; }
  .quiz-start-title { font-size: clamp(1.4rem, 3vw, 2rem); margin-bottom: 12px; line-height: 1.35; font-family: var(--font); }
  .quiz-start-desc { color: var(--muted); line-height: 1.8; margin-bottom: 24px; font-family: var(--font); }
  .quiz-start-info {
    display: flex; flex-direction: column; gap: 10px;
    margin-bottom: 28px; padding: 16px; border-radius: 10px;
    background: var(--surface); border: 1px solid var(--border);
  }
  .quiz-info-item { display: flex; align-items: center; gap: 8px; font-size: .92rem; color: var(--muted); font-family: var(--font); }
  .quiz-info-label { font-weight: 700; color: var(--text); }

  /* ── Segmented Progress ─────────────────────────────────────────────── */
  .quiz-progress-wrap { margin-bottom: 16px; }
  .quiz-progress-label { font-size: .88rem; color: var(--muted); margin-bottom: 8px; font-family: var(--font); }
  .quiz-segs { display: flex; gap: 4px; }
  .q-seg { flex: 1; height: 5px; border-radius: 999px; background: rgba(255,255,255,.08); transition: background .35s; }
  .q-seg.done   { background: var(--accent); }
  .q-seg.active { background: rgba(158,230,207,.4); }

  /* ── Question card ──────────────────────────────────────────────────── */
  .quiz-question-card {
    padding: 28px 32px 32px;
    position: relative;
    overflow: hidden;
  }
  .quiz-question-card::before {
    content: "";
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent, transparent 10px,
      rgba(255,255,255,.018) 10px, rgba(255,255,255,.018) 11px
    );
    pointer-events: none;
  }

  .quiz-question-header { margin-bottom: 16px; }
  .quiz-diff-badge {
    display: inline-block; padding: 3px 12px; border-radius: 999px;
    font-size: .78rem; font-weight: 700; letter-spacing: .05em;
    font-family: var(--font); border: 1px solid;
  }
  .diff-easy   { color: #6be1a4; border-color: rgba(107,225,164,.35); background: rgba(107,225,164,.08); }
  .diff-medium { color: #e8c07a; border-color: rgba(232,192,122,.35); background: rgba(232,192,122,.08); }
  .diff-hard   { color: #e88aaa; border-color: rgba(232,138,170,.35); background: rgba(232,138,170,.08); }

  .quiz-question-text {
    font-size: 1.1rem; font-weight: 700; line-height: 1.7;
    margin-bottom: 24px; font-family: var(--font);
  }

  /* ── Options with letter badges ─────────────────────────────────────── */
  .quiz-opts { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .quiz-opt {
    width: 100%; display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; border-radius: 13px;
    background: rgba(255,255,255,.03); border: 1.5px solid rgba(255,255,255,.1);
    color: #e8f0ec; font-family: 'Cairo', Tahoma, Arial, sans-serif; font-size: .97rem;
    cursor: pointer; transition: border-color .2s, background .2s;
    line-height: 1.5; text-align: start;
  }
  .quiz-opt:hover:not(:disabled) {
    border-color: rgba(158,230,207,.55);
    background: rgba(158,230,207,.05);
  }

  .opt-ltr {
    flex-shrink: 0;
    width: 32px; height: 32px; border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,.18);
    display: flex; align-items: center; justify-content: center;
    font-size: .82rem; font-weight: 700; font-family: 'Cairo', Tahoma, Arial, sans-serif;
    color: rgba(255,255,255,.55); background: rgba(255,255,255,.05);
    transition: background .2s, border-color .2s, color .2s;
  }
  .opt-txt { flex: 1; }

  .quiz-opt.opt-correct { border-color: #6be1a4; background: rgba(107,225,164,.1); color: #6be1a4; cursor: default; }
  .quiz-opt.opt-correct .opt-ltr { background: #6be1a4; border-color: #6be1a4; color: #001f15; font-weight: 800; }
  .quiz-opt.opt-wrong   { border-color: #e07070; background: rgba(224,112,112,.1); color: #e07070; cursor: default; }
  .quiz-opt.opt-wrong   .opt-ltr { background: #e07070; border-color: #e07070; color: #fff; font-weight: 800; }
  .quiz-opt.opt-dim     { opacity: .35; cursor: default; }

  /* ── Hint (collapsible dotted box) ──────────────────────────────────── */
  .hint-wrap { margin-bottom: 16px; }
  .hint-toggle {
    display: inline-flex; align-items: center; gap: 6px;
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-size: .88rem; font-family: var(--font);
    padding: 4px 0; transition: color .15s;
  }
  .hint-toggle:hover { color: var(--accent); }
  .hint-body {
    margin-top: 10px; padding: 12px 16px;
    border: 1.5px dashed rgba(158,230,207,.25); border-radius: 8px;
    font-size: .92rem; color: var(--muted); line-height: 1.7;
    background: rgba(158,230,207,.04); font-family: var(--font);
  }

  /* ── Feedback ───────────────────────────────────────────────────────── */
  .quiz-feedback { margin-bottom: 16px; padding: 12px 16px; border-radius: 8px; background: var(--surface); }
  .quiz-fb-result { font-weight: 700; font-size: .95rem; margin-bottom: 4px; font-family: var(--font); }
  .fb-correct { color: #6be1a4; }
  .fb-wrong   { color: #e07070; }
  .quiz-fb-ref { font-size: .82rem; color: var(--muted); margin: 0; font-family: var(--font); }

  /* ── Next button ────────────────────────────────────────────────────── */
  .quiz-next-btn { margin-top: 8px; width: 100%; justify-content: center; gap: 8px; font-family: var(--font); }

  /* ── Register ───────────────────────────────────────────────────────── */
  .quiz-register-card { padding: 36px; text-align: center; }
  .quiz-register-icon { margin-bottom: 16px; }
  .quiz-register-title { font-size: 1.3rem; margin-bottom: 6px; font-family: var(--font); }
  .quiz-register-sub { color: var(--muted); font-size: .9rem; margin-bottom: 24px; font-family: var(--font); }
  .quiz-field { margin-bottom: 14px; text-align: start; }
  .quiz-input {
    width: 100%; padding: 12px 16px; border-radius: 10px;
    background: var(--surface); border: 1px solid var(--border);
    color: var(--text); font-family: var(--font); font-size: .97rem;
    transition: border-color .15s;
  }
  .quiz-input:focus { outline: none; border-color: var(--accent-border); }
  .quiz-input::placeholder { color: var(--muted); }
