---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_MAP, getCategory } from '../../utils/blog';
import ArticleCard from '../../components/ArticleCard.astro';

const allPosts = (await getCollection('blog_ar', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// التصنيفات الفريدة الموجودة فعلياً — بالترتيب الأول ظهوراً
const seenLabels = new Set<string>();
const activeCategories = allPosts
  .map(p => getCategory(p.data.tags))
  .filter((c): c is NonNullable<typeof c> => {
    if (!c || seenLabels.has(c.label)) return false;
    seenLabels.add(c.label);
    return true;
  });

const currentPath = Astro.url.pathname;
const [latestPost, ...restPosts] = allPosts;
---

<Base
  title="المدونة — ياسر الجيادي"
  description="مقالات متخصصة في الرواتب، الحوكمة، الامتثال، وتقنيات إدارة الموارد البشرية في السوق السعودية."
  lang="ar"
  dir="rtl"
>
  <Navbar lang="ar" currentPath={currentPath} />

  <div class="page-header">
    <div class="container">
      <span class="section-label">المدونة</span>
      <h1 style="margin-bottom:12px;">مقالات الموارد البشرية</h1>
      <p style="color:var(--muted); max-width:52ch; font-size:1.05rem;">
        مقالات متخصصة في الرواتب، الحوكمة، الامتثال، وتقنيات إدارة الموارد البشرية في السوق السعودية.
        مقال جديد كل أسبوع.
      </p>

      {activeCategories.length > 0 && (
        <div class="cat-filter" style="margin-top:28px;" role="group" aria-label="فلترة حسب التصنيف">
          <button class="cat-btn active" data-filter="all"
                  aria-pressed="true">الكل</button>
          {activeCategories.map(cat => (
            <button class="cat-btn" data-filter={cat.label}
                    style={`--cat-color:${cat.color}`}
                    aria-pressed="false">
              {cat.label}
            </button>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="container" style="padding-bottom:80px;">
    {allPosts.length === 0 ? (
      <div style="text-align:center; padding:80px 0; color:var(--muted);">
        <p style="font-size:1.1rem;">لا توجد مقالات بعد. قريباً...</p>
      </div>
    ) : (
      <div class="blog-grid">

        {/* بطاقة المقال الأحدث — wide */}
        {latestPost && (
          <ArticleCard
            variant="wide"
            href={`/blog/${latestPost.id}/`}
            title={latestPost.data.title}
            description={latestPost.data.description}
            cover={latestPost.data.cover}
            tags={latestPost.data.tags}
            pubDate={latestPost.data.pubDate}
            body={latestPost.body}
            lang="ar"
          />
        )}

        {/* بقية المقالات */}
        {restPosts.map(post => (
          <ArticleCard
            href={`/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            cover={post.data.cover}
            tags={post.data.tags}
            pubDate={post.data.pubDate}
            body={post.body}
            lang="ar"
          />
        ))}

      </div>
    )}
  </div>

  <Footer lang="ar" />
</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const cards = document.querySelectorAll<HTMLElement>('[data-category]');

  btns.forEach(btn => btn.addEventListener('click', () => {
    btns.forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');

    const f = btn.dataset.filter;
    cards.forEach(c => {
      c.style.display = (f === 'all' || c.dataset.category === f) ? '' : 'none';
    });
  }));
</script>
