    <div class="footer-inner">
      <span>
        {isAr ? `© ${year} ياسر الجيادي` : `© ${year} Yasir Aljiyadi`}
      </span>

      <nav class="footer-social" aria-label="روابط التواصل">
        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/in/yasir-aljiyadi-21b514160/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8.5h4V23h-4V8.5zm7 0h3.83v1.98h.05c.53-1 1.82-2.06 3.75-2.06 4.01 0 4.75 2.64 4.75 6.07V23h-4v-5.91c0-1.41-.03-3.22-1.96-3.22-1.96 0-2.26 1.53-2.26 3.12V23h-4V8.5z"/>
