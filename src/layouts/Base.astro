---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: 'ar' | 'en';
  dir?: 'rtl' | 'ltr';
}

const {
  title,
  description = 'ياسر الجيادي — مدونة الموارد البشرية | HR Blog',
  image = '/Yasir-Aljiyadi-photo.png',
  lang = 'ar',
  dir = 'rtl',
} = Astro.props;

const canonical = Astro.url.href;
---

<!doctype html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://yasiraboanmar.com${image}`} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://yasiraboanmar.com${image}`} />

  <!-- Hreflang -->
  {lang === 'ar' && <link rel="alternate" hreflang="ar" href="https://yasiraboanmar.com/" />}
  {lang === 'ar' && <link rel="alternate" hreflang="en" href="https://yasiraboanmar.com/en/" />}
  {lang === 'en' && <link rel="alternate" hreflang="en" href="https://yasiraboanmar.com/en/" />}
  {lang === 'en' && <link rel="alternate" hreflang="ar" href="https://yasiraboanmar.com/" />}
  <link rel="alternate" hreflang="x-default" href="https://yasiraboanmar.com/" />

  <!-- RSS -->
  <link
    rel="alternate"
    type="application/rss+xml"
    title={lang === 'ar' ? 'ياسر الجيادي — مدونة HR' : 'Yasir Aljiyadi — HR Blog'}
    href={lang === 'ar' ? '/rss.xml' : '/en/rss.xml'}
  />

  <!-- Favicon -->
  <link rel="icon" href="/Y-icon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/Y-icon.svg" />

  <!-- Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" />
  </noscript>

  <!-- Google Consent Mode v2 -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    // Default consent to denied (will be updated based on user choice)
    gtag('consent', 'default', {
      'analytics_storage': 'denied',
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'wait_for_update': 500
    });
  </script>

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4997003296069618" crossorigin="anonymous"></script>

  <!-- Floating bubbles: CSS-only, no JS -->
  <style>
    /* z-index:-1 renders between the canvas background and page content.
       prefers-reduced-motion in global.css disables all animations globally. */
    .bubbles-bg {
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      overflow: hidden;      /* clips bubbles at viewport edges — prevents horizontal scroll */
    }
    .bubble {
      position: absolute;
      bottom: -200px;
      --op: .06;
      aspect-ratio: 2440.74 / 861.4;      /* matches SVG viewBox ratio */
    }
    .bubble svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    @keyframes bubble-rise-r {
      0%   { transform: translateY(0) translateX(0);    opacity: 0; }
      8%   { opacity: var(--op); }
      92%  { opacity: var(--op); }
      100% { transform: translateY(-120vh) translateX(20px); opacity: 0; }
    }
    @keyframes bubble-rise-l {
      0%   { transform: translateY(0) translateX(0);     opacity: 0; }
      8%   { opacity: var(--op); }
      92%  { opacity: var(--op); }
      100% { transform: translateY(-120vh) translateX(-20px); opacity: 0; }
    }

    /* Color cycle: accent-strong → muted gray → back; color drives currentColor → background-color */
    @keyframes color-cycle {
      0%   { color: #1b7742; }
      50%  { color: #7a9080; }
      100% { color: #1b7742; }
    }

    /*
     * 8 bubbles — sizes 120–280px, distributed in ~11% left intervals.
     * Adjacent positions carry maximally different delays to keep bubbles
     * at different heights simultaneously (no two neighbours share a phase):
     *   left:  3  14  25  37  50  62  74  85  (≥11% apart)
     *   delay: 0 -12  -6 -18  -3 -15  -9 -21  (≥6s apart between neighbours)
     */
    .b1 { width:150px; left: 3%;  --op:.15; animation:bubble-rise-r 22s   0s linear infinite, color-cycle 35s   0s ease-in-out infinite; }
    .b2 { width:200px; left:14%;  --op:.16; animation:bubble-rise-l 18s -12s linear infinite, color-cycle 38s -12s ease-in-out infinite; }
    .b3 { width:130px; left:25%;  --op:.14; animation:bubble-rise-r 26s  -6s linear infinite, color-cycle 32s -25s ease-in-out infinite; }
    .b4 { width:250px; left:37%;  --op:.15; animation:bubble-rise-l 20s -18s linear infinite, color-cycle 40s  -7s ease-in-out infinite; }
    .b5 { width:180px; left:50%;  --op:.14; animation:bubble-rise-r 24s  -3s linear infinite, color-cycle 36s -18s ease-in-out infinite; }
    .b6 { width:120px; left:62%;  --op:.17; animation:bubble-rise-l 16s -15s linear infinite, color-cycle 33s -30s ease-in-out infinite; }
    .b7 { width:280px; left:74%;  --op:.14; animation:bubble-rise-r 28s  -9s linear infinite, color-cycle 37s  -4s ease-in-out infinite; }
    .b8 { width:160px; left:85%;  --op:.16; animation:bubble-rise-l 22s -21s linear infinite, color-cycle 34s -22s ease-in-out infinite; }
  </style>

  <!-- Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Yasir Aljiyadi",
    "alternateName": "ياسر الجيادي",
    "url": "https://yasiraboanmar.com",
    "image": "https://yasiraboanmar.com/Yasir-Aljiyadi-photo.png",
    "jobTitle": "HR Leader",
    "sameAs": [
      "https://x.com/Yasir_Aljiyadi",
      "https://www.linkedin.com/in/yasir-aljiyadi-21b514160/",
      "https://github.com/yasiraboomar"
    ]
  }
  </script>

</head>
<body>
  <div class="bubbles-bg" aria-hidden="true">
