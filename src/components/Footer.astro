---
export interface Props { lang?: 'ar' | 'en'; }
const { lang = 'ar' } = Astro.props;
const isAr = lang === 'ar';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="copyright">
          {isAr ? `© ${year} ياسر الجيادي` : `© ${year} Yasir Aljiyadi`}
        </span>

        <nav class="footer-links" aria-label={isAr ? 'روابط قانونية' : 'Legal links'}>
          <a href={isAr ? '/privacy' : '/en/privacy'}>
            {isAr ? 'الخصوصية' : 'Privacy'}
          </a>
          <a href={isAr ? '/terms' : '/en/terms'}>
            {isAr ? 'الشروط' : 'Terms'}
          </a>
          <a href={isAr ? '/disclaimer' : '/en/disclaimer'}>
            {isAr ? 'إخلاء المسؤولية' : 'Disclaimer'}
          </a>
        </nav>
      </div>

      <nav class="footer-social" aria-label="روابط التواصل">
        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/in/yasir-aljiyadi-21b514160/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8.5h4V23h-4V8.5zm7 0h3.83v1.98h.05c.53-1 1.82-2.06 3.75-2.06 4.01 0 4.75 2.64 4.75 6.07V23h-4v-5.91c0-1.41-.03-3.22-1.96-3.22-1.96 0-2.26 1.53-2.26 3.12V23h-4V8.5z"/>
          </svg>
        </a>
        <!-- X -->
        <a href="https://x.com/Yasir_Aljiyadi" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M18.244 2H21l-6.56 7.5L22.5 22H15l-5.02-6.54L3.9 22H2l7.09-8.1L1.5 2H9l4.52 5.88L18.244 2Zm-2.6 18h2.031L7.406 4H5.312L15.644 20Z"/>
          </svg>
        </a>
        <!-- RSS -->
        <a href="/rss.xml" aria-label="RSS Feed">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .copyright {
    white-space: nowrap;
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
  }

  .footer-links a {
    color: var(--gray-600);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .footer-links a:hover {
    color: var(--gray-900);
    text-decoration: underline;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-left {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .footer-links {
      gap: 0.75rem;
    }
  }
</style>
