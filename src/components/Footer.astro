          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path d="M18.244 2H21l-6.56 7.5L22.5 22H15l-5.02-6.54L3.9 22H2l7.09-8.1L1.5 2H9l4.52 5.88L18.244 2Zm-2.6 18h2.031L7.406 4H5.312L15.644 20Z"/>
