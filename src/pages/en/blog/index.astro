---
import Base from '../../../layouts/Base.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog_en', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];
const currentPath = Astro.url.pathname;
---

<Base
  title="Blog — Yasir Aljiyadi"
  description="Weekly articles on HR: payroll, governance, Saudi labor law, and HR technology."
  lang="en"
  dir="ltr"
>
  <Navbar lang="en" currentPath={currentPath} />

  <div class="page-header">
    <div class="container">
      <span class="section-label">Blog</span>
      <h1 style="margin-bottom:12px;">HR Articles</h1>
      <p style="color:var(--muted); max-width:52ch; font-size:1.05rem;">
        Specialized articles on payroll, governance, compliance, and HR technology in the Saudi market.
        A new article every week.
      </p>
      {allTags.length > 0 && (
        <div class="tags" style="margin-top:24px;">
          {allTags.map(tag => <span class="tag">#{tag}</span>)}
        </div>
      )}
    </div>
  </div>

  <div class="container" style="padding-bottom:80px;">
    {allPosts.length === 0 ? (
      <div style="text-align:center; padding:80px 0; color:var(--muted);">
        <p style="font-size:1.1rem;">No articles yet. Coming soon...</p>
      </div>
    ) : (
      <div class="blog-grid">
        {allPosts.map(post => (
          <a class="blog-card" href={`/en/blog/${post.id}/`}>
            <div class="blog-card-meta">
              {post.data.tags[0] && <span class="blog-card-tag">{post.data.tags[0]}</span>}
              <span>{post.data.pubDate.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</span>
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
            <div class="blog-card-footer">
              Read article
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>

  <Footer lang="en" />
</Base>
