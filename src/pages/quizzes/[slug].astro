---
import QuizPage from '../../components/QuizPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const quizzes = await getCollection('quizzes_ar');
  return quizzes.map(q => ({
    params: { slug: q.id },
    props:  { quiz: q.data },
  }));
}

const { quiz } = Astro.props;
---

<QuizPage lang="ar" quiz={quiz} currentPath={Astro.url.pathname} image="/images/quizzes/quiz-og-cover.png" />
